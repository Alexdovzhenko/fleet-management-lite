generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============ CORE ENTITIES ============

model Company {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  address   String?
  city      String?
  state     String?
  zip       String?
  logo      String?
  banner    String?
  website   String?
  slug      String?  @unique
  about     String?
  affiliateAbout    String?
  clientAbout       String?
  clientVehicleIds  String[]
  instagramUrl      String?
  facebookUrl       String?
  tiktokUrl         String?
  xUrl              String?
  linkedinUrl       String?
  timezone  String   @default("America/New_York")
  onboardingCompleted Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  drivers   Driver[]
  vehicles  Vehicle[]
  customers Customer[]
  trips        Trip[]
  invoices     Invoice[]
  settings     CompanySettings?
  serviceTypes ServiceType[]
  invites      CompanyInvite[]

  sentConnections     AffiliateConnection[] @relation("SentConnections")
  receivedConnections AffiliateConnection[] @relation("ReceivedConnections")

  favoritesAdded AffiliateFavorite[] @relation("FavoriteOwner")
  favoritedBy    AffiliateFavorite[] @relation("FavoritedBy")

  farmOutsSent     FarmOut[] @relation("FarmOutsSent")
  farmOutsReceived FarmOut[] @relation("FarmOutsReceived")

  appNotifications AppNotification[]
  addresses        CompanyAddress[]
  quoteRequests    QuoteRequest[]
}

model CompanyAddress {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name     String?   // Optional venue/location label (hotel, venue, etc.)
  address1 String    // Primary street address
  address2 String?
  city     String?
  state    String?
  zip      String?
  country  String?
  phone    String?
  notes    String?

  useCount   Int      @default(1)
  lastUsedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, address1])
}

model User {
  id        String   @id @default(cuid())
  authId    String   @unique
  email     String   @unique
  name      String
  phone     String?
  role      UserRole @default(DISPATCHER)
  avatarUrl String?
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([authId])
}

enum UserRole {
  OWNER
  DISPATCHER
  VIEWER
}

model Driver {
  id              String       @id @default(cuid())
  name            String
  email           String?
  phone           String
  licenseNumber   String?
  licenseExpiry   DateTime?
  avatarUrl           String?
  licensePhotoFront   String?
  licensePhotoBack    String?
  document1Url        String?
  document1Name       String?
  document2Url        String?
  document2Name       String?
  status              DriverStatus @default(ACTIVE)
  notes               String?
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  trips            Trip[] @relation("PrimaryDriver")
  secondaryTrips   Trip[] @relation("SecondaryDriver")
  defaultVehicleId String?
  defaultVehicle   Vehicle?             @relation("DefaultDriver", fields: [defaultVehicleId], references: [id])
  availability     DriverAvailability[]

  @@index([companyId])
}

enum DriverStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
}

model DriverAvailability {
  id          String  @id @default(cuid())
  driverId    String
  driver      Driver  @relation(fields: [driverId], references: [id], onDelete: Cascade)
  dayOfWeek   Int
  startTime   String
  endTime     String
  isAvailable Boolean @default(true)

  @@unique([driverId, dayOfWeek])
}

model Vehicle {
  id           String        @id @default(cuid())
  name         String
  type         VehicleType
  capacity     Int
  licensePlate String?
  color        String?
  year         Int?
  make         String?
  model        String?
  photoUrl        String?
  photos          String[]
  status          VehicleStatus @default(ACTIVE)
  notes           String?
  hideFromProfile Boolean       @default(false)
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  trips          Trip[] @relation("PrimaryVehicle")
  secondaryTrips Trip[] @relation("SecondaryVehicle")
  defaultDrivers Driver[] @relation("DefaultDriver")

  @@index([companyId])
}

enum VehicleType {
  SEDAN
  SUV
  STRETCH_LIMO
  SPRINTER
  PARTY_BUS
  COACH
  OTHER
}

enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  OUT_OF_SERVICE
}

model Customer {
  id                   String       @id @default(cuid())
  customerNumber       String?
  name                 String
  email                String?
  phone                String?
  company              String?
  isBillingContact     Boolean      @default(false)
  isPassenger          Boolean      @default(false)
  isBookingContact     Boolean      @default(false)
  homeAddress          String?
  addressLine2         String?
  city                 String?
  state                String?
  zip                  String?
  country              String?
  workAddress          String?
  notes                String?
  specialRequests      String?
  driverNotes          String?
  preferredDriverId    String?
  preferredVehicleType VehicleType?
  companyId            String
  companyRef           Company      @relation(fields: [companyId], references: [id])
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  trips    Trip[]
  invoices Invoice[]

  @@unique([companyId, customerNumber])
  @@index([companyId])
  @@index([phone])
  @@index([email])
}

// ============ TRIPS ============

model Trip {
  id           String     @id @default(cuid())
  tripNumber   String     @unique
  status       TripStatus @default(QUOTE)
  tripType     String     @default("ONE_WAY")
  pickupDate   DateTime
  pickupTime   String
  pickupAddress  String
  pickupLat      Float?
  pickupLng      Float?
  pickupNotes    String?
  dropoffAddress String
  dropoffLat     Float?
  dropoffLng     Float?
  dropoffNotes   String?

  flightNumber  String?
  flightArrival DateTime?
  flightStatus  String?
  airportCode   String?

  passengerCount Int     @default(1)
  luggageCount   Int?
  passengerName  String?
  passengerPhone String?
  passengerEmail String?

  driverId  String?
  driver    Driver?  @relation("PrimaryDriver", fields: [driverId], references: [id])
  vehicleId String?
  vehicle   Vehicle? @relation("PrimaryVehicle", fields: [vehicleId], references: [id])

  secondaryDriverId  String?
  secondaryDriver    Driver?  @relation("SecondaryDriver", fields: [secondaryDriverId], references: [id])
  secondaryVehicleId String?
  secondaryVehicle   Vehicle? @relation("SecondaryVehicle", fields: [secondaryVehicleId], references: [id])

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  price        Decimal? @db.Decimal(10, 2)
  gratuity     Decimal? @db.Decimal(10, 2)
  totalPrice   Decimal? @db.Decimal(10, 2)
  pricingNotes String?

  meetAndGreet     Boolean @default(false)
  childSeat        Boolean @default(false)
  childSeatDetails String?
  wheelchairAccess Boolean @default(false)
  vip              Boolean @default(false)
  clientRef        String?
  notes            String?
  internalNotes    String?

  driverEnRouteAt    DateTime?
  driverArrivedAt    DateTime?
  passengerOnBoardAt DateTime?
  tripCompletedAt    DateTime?

  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stops         TripStop[]
  invoice       Invoice?
  notifications TripNotification[]
  farmOuts      FarmOut[]

  @@index([companyId])
  @@index([status])
  @@index([pickupDate])
  @@index([driverId])
  @@index([secondaryDriverId])
  @@index([customerId])
}

model TripStop {
  id          String  @id @default(cuid())
  tripId      String
  trip        Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  order       Int
  address     String
  lat         Float?
  lng         Float?
  notes       String?
  arrivalTime String?

  @@index([tripId])
}

enum TripStatus {
  QUOTE
  CONFIRMED
  DISPATCHED
  DRIVER_EN_ROUTE
  DRIVER_ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

model ServiceType {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  value       String
  label       String
  description String?
  iconName    String   @default("Car")
  color       String   @default("bg-gray-100 text-gray-600")
  isBuiltIn   Boolean  @default(false)
  isEnabled   Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, value])
  @@index([companyId])
}

model TripNotification {
  id           String              @id @default(cuid())
  tripId       String
  trip         Trip                @relation(fields: [tripId], references: [id], onDelete: Cascade)
  type         NotificationType
  channel      NotificationChannel
  recipient    String
  sentAt       DateTime?
  deliveredAt  DateTime?
  failedAt     DateTime?
  errorMessage String?
  content      String

  @@index([tripId])
}

enum NotificationType {
  CONFIRMATION
  REMINDER_24H
  REMINDER_1H
  DRIVER_ASSIGNED
  DRIVER_EN_ROUTE
  DRIVER_ARRIVED
  TRIP_COMPLETED
  CANCELLED
}

enum NotificationChannel {
  SMS
  EMAIL
}

// ============ INVOICES ============

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  status        InvoiceStatus @default(DRAFT)
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id])
  tripId        String?       @unique
  trip          Trip?         @relation(fields: [tripId], references: [id])
  subtotal      Decimal       @db.Decimal(10, 2)
  gratuity      Decimal?      @db.Decimal(10, 2)
  tax           Decimal?      @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  notes         String?
  dueDate       DateTime?
  paidAt        DateTime?
  paymentMethod String?
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([companyId])
  @@index([customerId])
  @@index([status])
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PAID
  OVERDUE
  CANCELLED
}

// ============ SETTINGS ============

model CompanySettings {
  id        String  @id @default(cuid())
  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id])

  sendConfirmationSms      Boolean @default(true)
  sendConfirmationEmail    Boolean @default(true)
  sendReminder24h          Boolean @default(true)
  sendDriverEnRoute        Boolean @default(true)
  sendDriverArrived        Boolean @default(true)

  confirmationSmsTemplate   String?
  confirmationEmailTemplate String?
  driverEnRouteTemplate     String?
  driverArrivedTemplate     String?

  defaultGratuityPercent Int?    @default(20)
  requirePaymentUpfront  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ TEAM INVITES ============

model CompanyInvite {
  id         String    @id @default(cuid())
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id])
  email      String
  role       UserRole  @default(DISPATCHER)
  token      String    @unique @default(cuid())
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([companyId])
  @@index([token])
}

// ============ FARM-OUT / FARM-IN ============

enum FarmOutStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

model FarmOut {
  id              String        @id @default(cuid())
  tripId          String
  trip            Trip          @relation(fields: [tripId], references: [id])
  fromCompanyId   String
  fromCompany     Company       @relation("FarmOutsSent", fields: [fromCompanyId], references: [id])
  toCompanyId     String
  toCompany       Company       @relation("FarmOutsReceived", fields: [toCompanyId], references: [id])
  status          FarmOutStatus @default(PENDING)
  message         String?
  agreedPrice     Decimal?      @db.Decimal(10, 2)
  vehicleType     VehicleType?
  parentFarmOutId String?
  parentFarmOut   FarmOut?      @relation("FarmOutChain", fields: [parentFarmOutId], references: [id])
  childFarmOuts   FarmOut[]     @relation("FarmOutChain")
  respondedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([tripId])
  @@index([fromCompanyId])
  @@index([toCompanyId])
  @@index([status])
}

// ============ AFFILIATES ============

enum AffiliateConnectionStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model AffiliateConnection {
  id            String                    @id @default(cuid())
  senderId      String
  receiverId    String
  status        AffiliateConnectionStatus @default(PENDING)
  affiliateCode String?                   @unique  // LC-XXXXX, generated when ACCEPTED
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  sender   Company @relation("SentConnections", fields: [senderId], references: [id])
  receiver Company @relation("ReceivedConnections", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
  @@index([status])
}

model AffiliateFavorite {
  id         String   @id @default(cuid())
  companyId  String
  favoriteId String
  createdAt  DateTime @default(now())

  company  Company @relation("FavoriteOwner", fields: [companyId], references: [id])
  favorite Company @relation("FavoritedBy", fields: [favoriteId], references: [id])

  @@unique([companyId, favoriteId])
  @@index([companyId])
}

// ============ IN-APP NOTIFICATIONS ============

enum AppNotificationType {
  AFFILIATE_INVITE_RECEIVED
  AFFILIATE_INVITE_ACCEPTED
  AFFILIATE_INVITE_DECLINED
  FARM_OUT_RECEIVED
  FARM_OUT_ACCEPTED
  FARM_OUT_DECLINED
  FARM_OUT_CANCELLED
  TRIP_PICKUP_TIME_CHANGED
  TRIP_PICKUP_ADDRESS_CHANGED
  TRIP_DROPOFF_ADDRESS_CHANGED
  TRIP_NOTES_CHANGED
  TRIP_STATUS_CHANGED
  TRIP_DRIVER_CHANGED
  TRIP_CANCELLED
  QUOTE_REQUEST_RECEIVED
}

// ============ QUOTE REQUESTS ============

enum QuoteRequestStatus {
  NEW
  PENDING
  ACCEPTED
  DECLINED
}

model QuoteRequest {
  id             String             @id @default(cuid())
  companyId      String
  company        Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)

  clientName     String
  clientPhone    String
  clientEmail    String?

  pickupDate     String
  pickupTime     String?
  pickupAddress  String
  dropoffAddress String
  vehicleType    VehicleType?
  passengerCount Int                @default(1)
  notes          String?

  status         QuoteRequestStatus @default(NEW)
  price          Decimal?           @db.Decimal(10, 2)

  tripId         String?            @unique

  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([companyId])
  @@index([status])
}

model AppNotification {
  id         String              @id @default(cuid())
  companyId  String
  company    Company             @relation(fields: [companyId], references: [id])
  type       AppNotificationType
  title      String
  body       String
  entityId   String?
  entityType String?
  metadata   Json?
  readAt     DateTime?
  createdAt  DateTime            @default(now())

  @@index([companyId])
  @@index([companyId, readAt])
  @@index([createdAt])
}
